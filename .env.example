# Copy to `.env` or `.env.local` for local overrides (optional).
# Local dev uses the Vite proxy to http://localhost:3001 when VITE_API_URL is unset.

# API base URL (no trailing slash on path before /admin/... routes)
VITE_API_URL=https://webbywrites.webbydemo.in/api

